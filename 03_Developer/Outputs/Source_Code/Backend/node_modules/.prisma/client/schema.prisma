generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CustomerTier {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(50)
  slug            String   @unique @db.VarChar(50)
  minSpent        BigInt   @map("min_spent")
  maintainSpent   BigInt   @default(0) @map("maintain_spent")
  discountPercent Decimal  @map("discount_percent") @db.Decimal(5, 2)
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  users User[]

  @@map("customer_tiers")
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone           String    @unique @db.VarChar(15)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  fullName        String    @map("full_name") @db.VarChar(100)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  role            String    @default("customer") @db.VarChar(20)
  tierId          String?   @map("tier_id") @db.Uuid
  totalSpent      BigInt    @default(0) @map("total_spent")
  pointsBalance   Int       @default(0) @map("points_balance")
  tierEvaluatedAt DateTime? @map("tier_evaluated_at")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  tier          CustomerTier? @relation(fields: [tierId], references: [id])
  otpCodes      OtpCode[]
  staffBranches StaffBranch[]

  @@index([phone])
  @@index([role])
  @@index([tierId])
  @@map("users")
}

model Branch {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @db.VarChar(100)
  address   String    @db.VarChar(500)
  phone     String?   @db.VarChar(15)
  latitude  Decimal?  @db.Decimal(10, 8)
  longitude Decimal?  @db.Decimal(11, 8)
  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  staffs StaffBranch[]

  @@map("branches")
}

model StaffBranch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@map("staff_branches")
}

model OtpCode {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String   @db.VarChar(10)
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("otp_codes")
}
